{
  "name": "dark-kitchen",
  "private": true,
  "workspaces": [
    "src/Web/packages/*",
    "src/Web/admin-panel",
    "src/Web/inventory-panel",
    "src/Web/storefront",
    "src/Web/kitchen-app",
    "src/Web/packing-terminal"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "eslint . --max-warnings=0 && npm run typecheck",
    "lint:fix": "eslint . --fix",
    "test": "npm run test:frontend",
    "test:all": "npm run test:dotnet && npm run test:frontend && npm run test:e2e",
    "test:architecture": "dotnet test tests/Architecture/DarkKitchen.ArchitectureTests/DarkKitchen.ArchitectureTests.csproj",
    "test:contracts": "dotnet test tests/Contracts/DarkKitchen.ContractTests/DarkKitchen.ContractTests.csproj",
    "test:dotnet": "dotnet test DarkKitchen.slnx",
    "test:e2e": "dotnet build src/DarkKitchen.AppHost/DarkKitchen.AppHost.csproj --no-restore -p:UseSharedCompilation=false -m:1 && playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:install": "playwright install chromium",
    "test:e2e:report": "playwright show-report artifacts/playwright-report",
    "test:e2e:reuse": "playwright test",
    "test:frontend": "npm run test --workspaces --if-present -- --run",
    "test:integration": "npm run test:integration:apphost && npm run test:integration:catalog && npm run test:integration:inventory && npm run test:integration:kds && npm run test:integration:orders && npm run test:integration:packing && npm run test:integration:storefront",
    "test:integration:apphost": "dotnet test tests/Integration/AppHost/DarkKitchen.AppHost.IntegrationTests/DarkKitchen.AppHost.IntegrationTests.csproj",
    "test:integration:catalog": "dotnet test tests/Integration/Catalog/DarkKitchen.Catalog.IntegrationTests/DarkKitchen.Catalog.IntegrationTests.csproj",
    "test:integration:inventory": "dotnet test tests/Integration/Inventory/DarkKitchen.Inventory.IntegrationTests/DarkKitchen.Inventory.IntegrationTests.csproj",
    "test:integration:kds": "dotnet test tests/Integration/Kds/DarkKitchen.Kds.IntegrationTests/DarkKitchen.Kds.IntegrationTests.csproj",
    "test:integration:orders": "dotnet test tests/Integration/OrderManagement/DarkKitchen.OrderManagement.IntegrationTests/DarkKitchen.OrderManagement.IntegrationTests.csproj",
    "test:integration:packing": "dotnet test tests/Integration/Packing/DarkKitchen.Packing.IntegrationTests/DarkKitchen.Packing.IntegrationTests.csproj",
    "test:integration:storefront": "dotnet test tests/Integration/Storefront/DarkKitchen.Storefront.IntegrationTests/DarkKitchen.Storefront.IntegrationTests.csproj",
    "typecheck": "npm run typecheck --workspaces",
    "dev:admin": "npm --workspace @dark-kitchen/admin-panel run dev",
    "dev:inventory": "npm --workspace @dark-kitchen/inventory-panel run dev",
    "dev:storefront": "npm --workspace @dark-kitchen/storefront run dev",
    "dev:kitchen": "npm --workspace @dark-kitchen/kitchen-app run dev",
    "dev:packing": "npm --workspace @dark-kitchen/packing-terminal run dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript-eslint": "^8.59.1"
  }
}
